# ── Server Environment Variables ──────────────────────────────────────────────
# LOCAL DEV: copy to .env and fill in your values
# RENDER:    add each key/value under Dashboard → Your Service → Environment

# Set to "production" on Render
NODE_ENV=production

# Render sets PORT automatically — do not add PORT to Render env vars
PORT=5003

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/inside-breach?retryWrites=true&w=majority

# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_random_64_byte_hex
JWT_REFRESH_SECRET=replace_with_another_random_64_byte_hex
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Must be "true" on Render (HTTPS is enforced)
COOKIE_SECURE=true

# Your Vercel frontend URL — comma-separated to allow multiple origins
# e.g. "https://your-app.vercel.app,http://localhost:5173"
CLIENT_URL=https://your-app.vercel.app

# Brevo email (for student credential emails)
BREVO_USER=your-sender@email.com
BREVO_SMTP_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
